<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>🏰 魔法三角形王國</title>
    <style>
        /* 引入可愛的圓體字型 */
        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@700;900&display=swap');

        body {
            font-family: 'Nunito', 'Microsoft JhengHei', 'Comic Sans MS', sans-serif;
            background-color: #e0f7fa; /* 淺藍色天空背景 */
            background-image: radial-gradient(#b2ebf2 20%, transparent 20%), radial-gradient(#b2ebf2 20%, transparent 20%);
            background-size: 40px 40px;
            background-position: 0 0, 20px 20px;
            color: #333;
            margin: 0;
            padding: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            height: 100vh;
            box-sizing: border-box;
            overflow: hidden; /* 防止 iPad 上下滾動 */
        }

        h1 {
            color: #ffb300;
            text-shadow: 2px 2px 0px #ff6f00, 4px 4px 0px rgba(0,0,0,0.1);
            font-size: 32px;
            margin: 10px 0;
            text-align: center;
        }

        #loading-screen {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: rgba(255, 255, 255, 0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
        }

        .loader {
            border: 8px solid #f3f3f3;
            border-top: 8px solid #ffb300;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        #camera-container {
            position: relative;
            width: 100%;
            max-width: 600px;
            aspect-ratio: 4/3;
            background-color: #000;
            border: 6px solid #ffb300;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            margin-bottom: 15px;
        }

        video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none; /* 隱藏原始影片，只顯示畫布 */
        }

        canvas {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
        }

        #crosshair {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 60px; height: 60px;
            border: 2px dashed rgba(255, 255, 255, 0.6);
            border-radius: 50%;
            pointer-events: none;
        }

        #result-panel {
            width: 100%;
            max-width: 600px;
            background-color: white;
            border-radius: 20px;
            padding: 20px;
            box-sizing: border-box;
            box-shadow: 0 8px 15px rgba(0,0,0,0.1);
            border: 4px solid #4fc3f7;
            text-align: center;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .type-badge {
            display: inline-block;
            background-color: #ff5252;
            color: white;
            padding: 10px 20px;
            border-radius: 30px;
            font-size: 24px;
            font-weight: 900;
            margin-bottom: 10px;
            box-shadow: 0 4px 0px #c62828;
        }

        #reason-text {
            font-size: 18px;
            color: #455a64;
            line-height: 1.5;
            margin: 0;
            font-weight: bold;
        }

        #start-btn {
            background-color: #4caf50;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 24px;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            box-shadow: 0 6px 0px #2e7d32;
            margin-top: 20px;
            font-family: inherit;
        }
        #start-btn:active {
            transform: translateY(6px);
            box-shadow: none;
        }

        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div id="loading-screen">
        <div class="loader"></div>
        <h2 style="color: #ffb300;">準備魔法放大鏡中...</h2>
        <p>請稍等一下下喔！</p>
    </div>

    <h1>🏰 魔法三角形王國 👑</h1>
    
    <div id="camera-container">
        <video id="videoInput" autoplay playsinline></video>
        <!-- 顯示處理後畫面的畫布 -->
        <canvas id="canvasOutput"></canvas>
        <!-- 幫助對準的準心 -->
        <div id="crosshair"></div>
    </div>
    
    <div id="result-panel">
        <div>
            <div id="triangle-type" class="type-badge" style="background-color: #9e9e9e; box-shadow: 0 4px 0px #616161;">
                尋找三角形中... 👀
            </div>
        </div>
        <p id="reason-text">請把畫好的三角形放在魔法放大鏡（鏡頭）前面喔！背景越乾淨越好！</p>
    <button id="start-btn" class="hidden" onclick="startCamera()">開啟魔法鏡頭 📷</button>
</div>

<script>
    let video = document.getElementById('videoInput');
    let canvas = document.getElementById('canvasOutput');
        let ctx = canvas.getContext('2d', { willReadFrequently: true });
        let streaming = false;
        let src, dst, gray, edges;
        let lastResultTime = 0;

    // 當 OpenCV 載入完成
    function onOpenCvReady() {
        document.getElementById('loading-screen').classList.add('hidden');
        document.getElementById('start-btn').classList.remove('hidden');
        document.getElementById('reason-text').innerText = "點擊下方的按鈕，開啟你的魔法鏡頭吧！";
    }

    // 載入失敗時的提示
    function onOpenCvError() {
        document.getElementById('loading-screen').innerHTML = '<div style="text-align:center;"><h2 style="color: #f44336;">哎呀！魔法工具下載失敗 😭</h2><p>這通常是因為網路比較慢或不穩。<br>請檢查網路後，重新整理網頁再試一次喔！</p></div>';
    }

    // 啟動鏡頭 (針對 iPad 後鏡頭優化)
        function startCamera() {
            document.getElementById('start-btn').classList.add('hidden');
            document.getElementById('reason-text').innerText = "魔法鏡頭開啟中...";

            // 請求後置鏡頭 (environment)
            let constraints = {
                video: { facingMode: "environment", width: { ideal: 640 }, height: { ideal: 480 } },
                audio: false
            };

            navigator.mediaDevices.getUserMedia(constraints)
                .then(function(stream) {
                    video.srcObject = stream;
                    video.play();
                    streaming = true;
                    video.oncanplay = function() {
                        // 設定畫布大小與影片一致
                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                        initOpenCV();
                        processVideo();
                    };
                })
                .catch(function(err) {
                    document.getElementById('reason-text').innerText = "哎呀！魔法鏡頭打不開 😭 請確認有沒有允許使用相機喔！";
                    console.error("相機錯誤:", err);
                });
        }

        function initOpenCV() {
            src = new cv.Mat(canvas.height, canvas.width, cv.CV_8UC4);
            dst = new cv.Mat(canvas.height, canvas.width, cv.CV_8UC4);
            gray = new cv.Mat();
            edges = new cv.Mat();
        }

        // 核心影像處理迴圈
        function processVideo() {
            if (!streaming) return;
            let begin = Date.now();

            // 將攝影機畫面畫到 Canvas 上
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            src.data.set(ctx.getImageData(0, 0, canvas.width, canvas.height).data);

            // 影像處理：灰階 -> 模糊 -> 邊緣偵測
            cv.cvtColor(src, gray, cv.COLOR_RGBA2GRAY);
            cv.GaussianBlur(gray, gray, new cv.Size(7, 7), 0, 0, cv.BORDER_DEFAULT);
            cv.Canny(gray, edges, 40, 120); // 調整閾值讓小朋友的鉛筆/蠟筆線條更容易被抓到

            let contours = new cv.MatVector();
            let hierarchy = new cv.Mat();
            cv.findContours(edges, contours, hierarchy, cv.RETR_EXTERNAL, cv.CHAIN_APPROX_SIMPLE);

            src.copyTo(dst);
            let largestTriangleArea = 0;
            let bestTriangle = null;

            // 找最大的三角形
            for (let i = 0; i < contours.size(); ++i) {
                let cnt = contours.get(i);
                let area = cv.contourArea(cnt);
                
                // 過濾小雜訊，只看夠大的形狀
                if (area > 2000) {
                    let approx = new cv.Mat();
                    let epsilon = 0.05 * cv.arcLength(cnt, true); // 5%的寬容度，讓手畫的線也能變形狀
                    cv.approxPolyDP(cnt, approx, epsilon, true);

                    // 如果是 3 個頂點 (三角形)
                    if (approx.rows === 3) {
                        if (area > largestTriangleArea) {
                            largestTriangleArea = area;
                            if (bestTriangle) bestTriangle.delete();
                            bestTriangle = approx.clone();
                        }
                    }
                    approx.delete();
                }
            }

            // 如果有找到三角形
            if (bestTriangle) {
                // 畫出粗粗的魔法外框 (黃色)
                let color = new cv.Scalar(255, 215, 0, 255); // 金黃色
                let poly = new cv.MatVector();
                poly.push_back(bestTriangle);
                cv.drawContours(dst, poly, 0, color, 6); // 6px粗線
                poly.delete();

                // 畫頂點的可愛圓圈 (紅色)
                for (let j = 0; j < 3; j++) {
                    let pt = new cv.Point(bestTriangle.data32S[j*2], bestTriangle.data32S[j*2+1]);
                    cv.circle(dst, pt, 8, new cv.Scalar(255, 0, 0, 255), -1);
                }

                // 取得三個頂點座標
                let p1 = { x: bestTriangle.data32S[0], y: bestTriangle.data32S[1] };
                let p2 = { x: bestTriangle.data32S[2], y: bestTriangle.data32S[3] };
                let p3 = { x: bestTriangle.data32S[4], y: bestTriangle.data32S[5] };

                // 每 0.5 秒更新一次文字，避免畫面閃爍太快讓小朋友眼花
                if (Date.now() - lastResultTime > 500) {
                    analyzeTriangleKidFriendly(p1, p2, p3);
                    lastResultTime = Date.now();
                }

                bestTriangle.delete();
            } else {
                if (Date.now() - lastResultTime > 1500) { // 如果超過1.5秒沒看到三角形才提示
                    updateUI("尋找三角形中... 👀", "#9e9e9e", "請把畫好的三角形放在魔法放大鏡前面喔！背景越乾淨越好！");
                }
            }

            // 將處理後的畫面顯示到 Canvas
            cv.imshow('canvasOutput', dst);
            contours.delete(); hierarchy.delete();

            // 控制處理速度，大約 15 FPS 即可，節省 iPad 電量
            let delay = 1000 / 15 - (Date.now() - begin);
            setTimeout(processVideo, delay > 0 ? delay : 0);
        }

        // 用小朋友聽得懂的方式分析三角形
        function analyzeTriangleKidFriendly(p1, p2, p3) {
            // 計算三邊長
            const dist = (p, q) => Math.sqrt(Math.pow(p.x - q.x, 2) + Math.pow(p.y - q.y, 2));
            let sides = [dist(p1, p2), dist(p2, p3), dist(p3, p1)];
            
            // 邊長由小到大排序：s1最矮，s3最長
            sides.sort((a, b) => a - b);
            let s1 = sides[0], s2 = sides[1], s3 = sides[2];

            // 算三個角 (用餘弦定理)
            const getAngle = (a, b, opp) => Math.acos((a*a + b*b - opp*opp) / (2 * a * b)) * (180 / Math.PI);
            let angleC = getAngle(s1, s2, s3); // 最大角

            // --- 魔法容錯設定 (為小朋友設計的超大寬容度) ---
            // 因為用手拿 iPad 會有「透視變形」(平面的東西看起來變斜的)
            const sideRatioTolerance = 0.25; // 25% 的長度差異內都算「一樣長」
            const angleTolerance = 12;       // 78度~102度 都當作「直角」(90度)

            // 判斷邏輯
            // 判斷等腰：最短和第二短差不多，或是 第二短和最長差不多
            let isIsosceles = ((s2 - s1) / s2 < sideRatioTolerance) || ((s3 - s2) / s3 < sideRatioTolerance);
            // 判斷等邊：最長和最短差不多
            let isEquilateral = ((s3 - s1) / s3 < sideRatioTolerance);
            // 判斷直角：最大角接近90度
            let isRight = Math.abs(angleC - 90) < angleTolerance;

            let typeStr = "";
            let color = "";
            let reasonStr = "";

            if (isEquilateral) {
                typeStr = "👑 等邊三角形";
                color = "#9c27b0"; // 紫色
                reasonStr = "國王說：太完美了！它的三個邊「幾乎一模一樣長」，就像三胞胎一樣整齊！";
            } else if (isIsosceles && isRight) {
                typeStr = "✨ 等腰直角三角形";
                color = "#ff9800"; // 橘色
                reasonStr = "哇！這是稀有的寶石！它有兩個邊一樣長（雙胞胎），而且還有一個像書本角落一樣的「方正大直角」！";
            } else if (isIsosceles) {
                typeStr = "👯 等腰三角形";
                color = "#4caf50"; // 綠色
                reasonStr = "你看！它有兩個邊是「一樣長」的喔！就像長著兩條一樣長腿的精靈！";
            } else if (isRight) {
                typeStr = "📐 直角三角形";
                color = "#2196f3"; // 藍色
                reasonStr = "發現了！它有一個角是方方正正的「直角」，就像積木的角落一樣，可以站得很穩！";
            } else {
                typeStr = "🎨 不等邊三角形";
                color = "#e91e63"; // 粉紅色
                reasonStr = "這是一個很有個性的形狀！它的三個邊「都不一樣長」，每個角也都不一樣大喔！";
            }

            updateUI(typeStr, color, reasonStr);
        }

        // 更新介面文字與顏色
        function updateUI(title, bgColor, desc) {
            let badge = document.getElementById('triangle-type');
            badge.innerText = title;
            badge.style.backgroundColor = bgColor;
            
            // 根據背景色自動計算一個深一點的顏色作為陰影
            let shadowColor = shadeColor(bgColor, -30);
            badge.style.boxShadow = `0 4px 0px ${shadowColor}`;
            
            document.getElementById('reason-text').innerText = desc;
        }

        // 輔助函數：用來加深顏色產生按鈕陰影效果
        function shadeColor(color, percent) {
            if (color.startsWith('#')) {
                let R = parseInt(color.substring(1,3),16);
                let G = parseInt(color.substring(3,5),16);
                let B = parseInt(color.substring(5,7),16);

                R = parseInt(R * (100 + percent) / 100);
                G = parseInt(G * (100 + percent) / 100);
                B = parseInt(B * (100 + percent) / 100);

                R = (R<255)?R:255;  
                G = (G<255)?G:255;  
                B = (B<255)?B:255;  

                let RR = ((R.toString(16).length==1)?"0"+R.toString(16):R.toString(16));
                let GG = ((G.toString(16).length==1)?"0"+G.toString(16):G.toString(16));
                let BB = ((B.toString(16).length==1)?"0"+B.toString(16):B.toString(16));

                return "#"+RR+GG+BB;
        }
        return "#333"; // 預設陰影
    }
</script>

<!-- 非同步載入 OpenCV.js (移至最後，避免函數未定義錯誤，並增加錯誤處理) -->
<script async src="https://docs.opencv.org/4.8.0/opencv.js" onload="onOpenCvReady();" onerror="onOpenCvError();" type="text/javascript"></script>
</body>
</html>
